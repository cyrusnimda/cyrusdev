---
import Layout from '../layouts/Layout.astro';

const services = [
  {
    title: "Web Development",
    description: "Full-stack web solutions using modern technologies like Astro, React, and Tailwind CSS. We build fast, responsive, and SEO-friendly websites.",
    icon: "🌐"
  },
  {
    title: "Python Development",
    description: "Powerful backend systems, automation scripts, and data analysis tools built with Python. Expertise in Django, Flask, and FastAPI.",
    icon: "🐍"
  },
  {
    title: "PHP Solutions",
    description: "Custom PHP development for dynamic websites and legacy system maintenance. Proficient in Laravel and WordPress development.",
    icon: "🐘"
  },
  {
    title: "API Integration",
    description: "Connecting your systems with third-party APIs (Stripe, SendGrid, etc.) to extend functionality and streamline workflows.",
    icon: "🔌"
  }
];
---

<Layout>
  <section class="py-16">
    <div class="text-center mb-16 animate-fade-in">
      <h1 class="text-4xl md:text-5xl font-bold mb-4 bg-clip-text text-transparent bg-gradient-to-r from-blue-400 to-emerald-400">Our Services</h1>
      <p class="text-gray-400 text-lg max-w-2xl mx-auto">
        Tailored technical solutions to bring your ideas to life.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 px-4">
      {services.map((service, index) => (
        <div class="bg-gray-800/50 p-8 rounded-2xl hover:bg-gray-800 transition-all duration-300 hover:-translate-y-2 border border-gray-700/50 hover:border-blue-500/30 group animate-fade-in-up" style={`animation-delay: ${index * 100}ms`}>
          <div class="text-4xl mb-6 bg-gray-700/50 w-16 h-16 flex items-center justify-center rounded-xl group-hover:scale-110 transition-transform">
            {service.icon}
          </div>
          <h3 class="text-2xl font-bold mb-3 text-white group-hover:text-blue-400 transition-colors">{service.title}</h3>
          <p class="text-gray-400 leading-relaxed">
            {service.description}
          </p>
        </div>
      ))}
    </div>
  </section>
</Layout>

<style>
  .animate-fade-in {
    animation: fadeIn 0.8s ease-out forwards;
    opacity: 0;
  }
  
  .animate-fade-in-up {
    animation: fadeInUp 0.8s ease-out forwards;
    opacity: 0;
    transform: translateY(20px);
  }

  @keyframes fadeIn {
    to { opacity: 1; }
  }

  @keyframes fadeInUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
