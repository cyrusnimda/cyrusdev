---
import Layout from '../layouts/Layout.astro';
import {CLOUDFLARE_APIKEY} from "astro:env/server";
---

<Layout>
	<section class="py-16 text-white">
		<div class="max-w-2xl px-4">
			<h1 class="text-3xl font-bold text-white mb-8">Contact</h1>
			
			<form id="contactForm" class="space-y-6" method="post" action="/api/contacto">
				<div>
					<label for="name" class="block text-sm font-medium text-cyan-100">Name</label>
					<input type="text" id="name" name="name" required class="mt-1 px-2 block w-full rounded-md border-cyan-200 bg-cyan-500 text-white shadow-sm focus:border-gray-500 focus:ring-gray-500" />
				</div>
				
				<div>
					<label for="email" class="block text-sm font-medium text-cyan-100">Email</label>
					<input type="email" id="email" name="email" required class="mt-1 px-2 block w-full rounded-md border-cyan-200 bg-cyan-500 text-white shadow-sm focus:border-cyan-500 focus:ring-cyan-500" />
				</div>
				
				<div>
					<label for="message" class="block text-sm font-medium text-cyan-100">Message</label>
					<textarea id="message" name="message" rows="4" required class="mt-1 px-2 block w-full rounded-md border-cyan-200 bg-cyan-500 text-white shadow-sm focus:border-cyan-500 focus:ring-cyan-500"></textarea>
				</div>
				
				<div class="cf-turnstile" data-theme="dark" data-sitekey={CLOUDFLARE_APIKEY}></div>
				
				<div>
					<button type="submit" class="inline-flex justify-center py-2 px-4 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-blue-600 hover:bg-blue-500 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-400">
						Send message
					</button>
				</div>
			</form>
		</div>
	</section>

	<script>
		// Load Cloudflare Turnstile script
		const turnstileScript = document.createElement('script');
		turnstileScript.src = 'https://challenges.cloudflare.com/turnstile/v0/api.js';
		document.head.appendChild(turnstileScript);

		// Contact form submission
		const contactForm = document.getElementById('contactForm');

		// check if form exists and it is the correct HTMLFormElement element
		if (!contactForm || !(contactForm instanceof HTMLFormElement)) {
			console.error('Contact form not found or not a form element');
		} else {
			contactForm.addEventListener('submit', async (event) => {
				event.preventDefault();
				console.log('Form submitted');

				const formData = new FormData(contactForm);
				const response = await fetch(contactForm.action, {
					method: contactForm.method,
					body: formData
				});

				if (response.ok) {
					alert('Message sent successfully');
					contactForm.reset();
				} else {
					alert('Error sending message');
				}
			});
		}
	</script>
</Layout>
